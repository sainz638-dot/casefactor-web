# ====================================
# ENVIRONMENT VARIABLES - EJEMPLO
# ====================================
#
# Copia este archivo a .env.local y llenar con tus valores
# NO commits de .env.local a GitHub (va en .gitignore)
#

# ====================================
# STRIPE (Para checkout futuro)
# ====================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_tu_clave_publica
STRIPE_SECRET_KEY=sk_live_tu_clave_secreta

# ====================================
# SUPABASE (Para base de datos futura)
# ====================================
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5...

# ====================================
# ANALYTICS (Google Analytics)
# ====================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ====================================
# CUSTOM EDITOR URL
# ====================================
NEXT_PUBLIC_EDITOR_URL=https://tu-dashboard.case-factor.com/disenador-publico

# ====================================
# NOTAS:
# ====================================
# - Variables que empiezan con NEXT_PUBLIC_ se exponen al cliente
# - NO incluyas secretos en NEXT_PUBLIC_*
# - En Vercel: Settings → Environment Variables → Añade estos valores
# - En local: Crea .env.local con los valores reales
